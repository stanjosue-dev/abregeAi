{
"manifest_version": 3,
"name": "AbregeAi",
"version": "1.0",
"description": "Abrege en un click et en quelques lignes les longs mails.",
"permissions": [
  "scripting",
  "activeTab"
],
"icons":{
  "128":"brain.png"
},
"host_permissions": [
    "https://abregeai.onrender.com/*" 
  ],
"content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],
"action":{
  "default_popup": "popup.html",
  "default-icon":"brain.png"
}
}