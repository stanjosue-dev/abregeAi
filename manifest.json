{
"manifest_version": 3,
"name": "AbregeAi",
"version": "1.0",
"description": "Abrege en un click et en quelques lignes les longs mails.",
"permissions": [
  "scripting",
  "activeTab"
],
"host_permissions": [
    "http://localhost:3000/*" 
  ],
"content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],
"action":{
  "default_popup": "popup.html"
}
}